# Dependencies
node_modules/

# Raw/source video processing folder (contains files >100MB; GitHub hard limit).
# Anchored with a leading slash so the rule only matches the top-level
# `video/` directory — without the slash this pattern also matched
# `src/components/Video/` on case-insensitive filesystems (macOS git
# default), silently dropping the VideoOverlay source from CI builds.
# Use Git LFS if you need to version these.
/video/

# Lap videos served by the app — excluded to keep the repo lean
public/assets/videos/
dist/assets/videos/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Local backup of pre-init git directory (do not track)
.git.backup/

# Debug / scratch artifacts left at repo root from prior dev sessions
/latest_track_check*.png
/track_*.png
/web_*.png
/web_*.txt
