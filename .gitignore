# Dependencies
node_modules/

# Build artifacts — rebuilt by Vite in CI (Dockerfile runs `npm run build`),
# so tracking the output here would only mean stale committed copies.
# Anchored with a leading slash so the rule matches only the top-level
# `dist/` directory.
/dist/

# Raw/source video processing folders (contain files >100MB; GitHub hard limit).
# Anchored with a leading slash so the rule only matches the top-level
# directories — without the slash this pattern also matched
# `src/components/Video/` on case-insensitive filesystems (macOS git
# default), silently dropping the VideoOverlay source from CI builds.
# Use Git LFS or push to a CDN (see `docs/BUNNY_VIDEOS.md`) instead.
/video/
/videos/

# Lap videos served by the dev server. The path holds symlinks pointing
# at `/videos/` (the raw-source dir above); the symlinks themselves stay
# out of git so a fresh clone doesn't inherit dangling links to a
# `/videos/` directory that doesn't exist on the new machine.
# `dist/assets/videos/` doesn't need its own rule — it's already covered
# by the `/dist/` ignore above.
public/assets/videos/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Local backup of pre-init git directory (do not track)
.git.backup/

# Debug / scratch artifacts left at repo root from prior dev sessions
/latest_track_check*.png
/track_*.png
/web_*.png
/web_*.txt
